# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
# Allow to type a directory name without prefixing it with "cd"
setopt autocd
# Set the shell to "emacs" mode. You can use -v instead to use the "ui" mode
bindkey -e
# End of lines configured by zsh-newuser-install

# Bind Ctrl+Right to move forward a word
bindkey '^[[1;5C' forward-word
# Bind Ctrl+Left to move backward a word
bindkey '^[[1;5D' backward-word
# Bind Delete to delete a word
bindkey "\e[3~" delete-char
# Home key binding: Move cursor to the beginning of the line
bindkey '\e[H' beginning-of-line
# End key binding: Move cursor to the end of the line
bindkey '\e[F' end-of-line

# The following lines were added by compinstall

zstyle ':completion:*' completer _complete _ignored
zstyle ':completion:*:default' menu select=0
zstyle :compinstall filename "$HOME/.zshrc"

# Load Git completion
zstyle ':completion:*:*:git:*' script ~/.zsh/git-completion.bash
fpath=(~/.zsh $fpath)

# Load other completion scripts from the standard directory
fpath=(~/.zsh/completions $fpath)

autoload -Uz compinit
compinit
# End of lines added by compinstall


# Add zsh auto suggestions (Arch and Fedora package layouts)
if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
	source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
elif [ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
	source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#696969"

# Add zsh syntax highlighting (Arch and Fedora package layouts)
if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
	source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
elif [ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
	source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# Show fastfetch at startup
if command -v fastfetch &> /dev/null && [ "$TERM_PROGRAM" != "vscode" ]; then
		fastfetch
fi

# Editor
export EDITOR="nvim"
export VISUAL="cursor"

{{- if ne .chezmoi.osRelease.id "fedora" }}
# Replace ls by eza
if command -v eza &> /dev/null; then
  alias ls="eza --icons --group-directories-first"
  alias ll="eza --icons --group-directories-first -l --git"
  alias lsa="eza --icons --group-directories-first -la --git"
  alias lt="eza --icons --group-directories-first --tree --level=2"
fi
{{- end }}
# Add shortcuts to nvim
alias vim="nvim"
alias vi="nvim"
alias v="nvim"
# Add shortcuts to lazygit
alias lg="lazygit"
# Add shortcuts to lazydocker
alias ld="lazydocker"
{{- if ne .install_purpose "terminal" }}
# Use kitten ssh to auto-copy terminfo to remote servers
if command -v kitten &> /dev/null; then
  alias ssh="kitten ssh"
fi
{{- end }}
# Add shortcut to gh-dash
alias dash="gh dash"
# Add shortucts to find the biggest files in the current directory (even hidden files)
alias big="sudo du -sh *(D) | sort -rh | head -n 10"

# PATH configurations are now in ~/.zshenv (sourced for all shells)
# This ensures VS Code and other tools can find pnpm, volta, etc.

# Pnpm completion (keep in .zshrc as it's interactive-only)
[[ -f ~/completion-for-pnpm.bash ]] && source ~/completion-for-pnpm.bash


# Set up television for terminal keybindings (CTRL+T file picker, CTRL+R history search)
if command -v tv &> /dev/null; then
  eval "$(tv init zsh)"

  # Override smart autocomplete to launch tv files channel on empty prompt
  # instead of falling back to zsh's expand-or-complete (shows "5500 possibilities")
  _tv_smart_autocomplete() {
    _disable_bracketed_paste
    local tokens prefix lbuf
    setopt localoptions noshwordsplit noksh_arrays noposixbuiltins

    tokens=(${(z)LBUFFER})
    if [ ${#tokens} -lt 1 ]; then
      zle -I
      local output
      output=$(tv files --no-status-bar --inline < /dev/tty)
      if [ -n "$output" ]; then
        LBUFFER="${(q)output} "
      fi
      zle reset-prompt
      _enable_bracketed_paste
      return
    fi

    [[ ${LBUFFER[-1]} == ' ' ]] && tokens+=("")
    if [[ ${LBUFFER} = *"${tokens[-2]-}${tokens[-1]}" ]]; then
      tokens[-2]="${tokens[-2]-}${tokens[-1]}"
      tokens=(${tokens[0,-2]})
    fi

    lbuf=$LBUFFER
    prefix=${tokens[-1]}
    [ -n "${tokens[-1]}" ] && lbuf=${lbuf:0:-${#tokens[-1]}}
    __tv_path_completion "$prefix" "$lbuf"
    _enable_bracketed_paste
  }
fi

# Store the ssh key for further use in git
if command -v keychain &> /dev/null; then
  eval "$(keychain --eval id_ed25519)"
fi

# Launch kitty dev environment: Claude (splits) + Neovim tabs
function kdev() {
	local dir="${1:-.}"
	dir="$(cd "$dir" && pwd)"
	local name="$(basename "$dir")"
	kitty --title "$name" --directory "$dir" --session <(cat <<EOF
new_tab Claude
layout splits
launch claude
launch --location=hsplit
launch --location=vsplit

new_tab Neovim
launch nvim
EOF
	) &>/dev/null & disown
}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# Initialize starship
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

# Initialize zoxide (--cmd cd replaces cd/cdi with smart zoxide versions)
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh --cmd cd)"
fi

{{- if .install_development }}
# Initialize WorkTrunk shell integration (directory switching for worktrees)
if command -v wt &> /dev/null; then
  eval "$(command wt config shell init zsh)"
fi

# Create/switch worktree + launch kitty dev environment
function wtstart() {
  local branch="$1"
  local is_new=false
  local orig_dir="$PWD"

  if [[ -z "$branch" ]]; then
    # No branch name: open interactive worktree picker
    wt switch || return 1
    # If the user escaped without picking, PWD hasn't changed
    [[ "$PWD" == "$orig_dir" ]] && return 0
  else
    # Create new worktree, or switch to existing one
    if wt switch --create "$branch" 2>/dev/null; then
      is_new=true
    elif ! wt switch "$branch"; then
      echo "error: failed to create or switch to worktree for '$branch'" >&2
      return 1
    fi

    # Copy gitignored files (e.g. .env.development.local) for new worktrees only
    if $is_new; then
      wt step copy-ignored
    fi
  fi

  local name="${branch:-$(git branch --show-current)}"
  local dir="$PWD"

  kitty --title "$name" --directory "$dir" --session <(cat <<EOF
new_tab Claude
layout splits
launch claude -n "$name"
launch --location=hsplit
launch --location=vsplit

new_tab Neovim
launch nvim
EOF
  ) &>/dev/null & disown

  builtin cd -- "$orig_dir"
}

# Remove all worktrees whose branches are already merged into main
function wtclean() {
  local branches
  branches=$(wt list --format=json 2>/dev/null | python3 -c "
import sys, json
for wt in json.load(sys.stdin):
    if wt.get('main_state') in ('integrated', 'empty') and not wt.get('is_main'):
        print(wt['branch'])
" 2>/dev/null)

  if [[ -z "$branches" ]]; then
    echo "No merged worktrees to clean up."
    return 0
  fi

  echo "Worktrees to remove:"
  echo "$branches" | sed 's/^/  - /'
  echo
  read -q "?Remove all? [y/N] " || { echo; return 0; }
  echo

  echo "$branches" | xargs wt remove -f
}

alias wts=wtstart
alias wtc=wtclean

# Rebase worktree(s) onto latest main and push
function wtupdate() {
  local branch="$1"

  echo "Fetching origin..."
  /usr/bin/git fetch origin

  local worktrees
  worktrees=$(wt list --format=json 2>/dev/null | python3 -c "
import sys, json
target = '$branch'
for wt in json.load(sys.stdin):
    if wt.get('is_main') or wt.get('kind') != 'worktree':
        continue
    if target and wt['branch'] != target:
        continue
    print(wt['branch'] + '\t' + wt['path'])
" 2>/dev/null)

  if [[ -z "$worktrees" ]]; then
    if [[ -n "$branch" ]]; then
      echo "error: worktree '$branch' not found" >&2
      return 1
    fi
    echo "No worktrees to update."
    return 0
  fi

  local failed=()
  while IFS=$'\t' read -r name path; do
    echo "Updating $name..."
    if /usr/bin/git -C "$path" rebase origin/main; then
      /usr/bin/git -C "$path" push --force-with-lease
    else
      echo "  Rebase conflict — aborting rebase for $name" >&2
      /usr/bin/git -C "$path" rebase --abort
      failed+=("$name")
    fi
  done <<< "$worktrees"

  if (( ${#failed[@]} > 0 )); then
    echo
    echo "Failed to update: ${failed[*]}"
    return 1
  fi
}

alias wtu=wtupdate
{{- end }}

# Source local overrides (not managed by chezmoi)
# Installers (bun, cargo, etc.) can safely add lines to ~/.zshrc.local
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

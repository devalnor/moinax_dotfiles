# Swaylock config — themed to match global palette
# Primary: #6464ff | Accent: #ff64ff | Font: Fira Code

image={{ .chezmoi.homeDir }}/Wallpapers/colorful.jpg
scaling=fill
font=Fira Code

ignore-empty-password
show-failed-attempts

# Default (idle)
color=00000066
ring-color=6464ffcc
inside-color=0000008a
line-color=00000000
text-color=aeaeaeff
separator-color=00000000

# Verifying
ring-ver-color=ff64ffcc
inside-ver-color=0000008a
line-ver-color=00000000
text-ver-color=ffffffff

# Wrong password
ring-wrong-color=f53c3ccc
inside-wrong-color=0000008a
line-wrong-color=00000000
text-wrong-color=ffffffff

# Key highlights
key-hl-color=ff64ff88
bs-hl-color=f53c3c88

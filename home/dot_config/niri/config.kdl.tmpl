// Niri config tuned to mirror Hyprland-like binds where possible.
// Keep this file conservative: invalid actions/keys can cause Niri to reject binds.
//
// Arrow-key modifier pattern:
//   Mod+Arrow              = Focus (column L/R, window U/D)
//   Mod+Page_Up/Down       = Focus workspace up/down
//   Mod+Alt+Arrow          = Cross-boundary (monitor L/R, workspace-move U/D)
//   Mod+Ctrl+Arrow         = Move window/column in direction
//   Mod+Shift+Arrow        = Resize (column width L/R, window height U/D)
//   Mod+Alt+Ctrl+Arrow     = Move column to monitor
//
// T-key modifier pattern (column/window management):
//   Mod+T                  = Toggle floating
//   Mod+Alt+T              = Consume window into column (stack)
//   Mod+Alt+Shift+T        = Expel window from column (undo stack)
//   Mod+Ctrl+T             = Set column to tabbed display
//   Mod+Ctrl+Shift+T       = Set column to normal display
//
// Non-1:1 mappings with Hyprland:
// - Scratchpad, group, split, opacity toggle have no Niri equivalent.
// - "move to workspace silently" is approximated with regular move-to-workspace.

input {
    focus-follows-mouse max-scroll-amount="0%"

    keyboard {
        xkb {
            layout "be,fr,us"
            // Layout switching handled by Mod+K (niri-switch-layout.sh)
            // grp:alt_shift_toggle removed to avoid conflicts with Mod+Alt+Shift combos
        }
    }

    touchpad {
        tap
        natural-scroll
    }
}

// Monitor layout: three monitors (matching Hyprland three_monitors layout).

// Left Monitor (DP-2) - Vertical
output "DP-2" {
    mode "2560x1440@59.951"
    transform "90"
    position x=-1440 y=-500

    layout {
        default-column-width { proportion 1.0; }
    }
}

// Center Monitor (DP-3) - Ultrawide, primary
output "DP-3" {
    mode "3440x1440@174.962"
    transform "normal"
    position x=0 y=0
}

// Right Monitor (DP-1) - Vertical
output "DP-1" {
    mode "2560x1440@59.951"
    transform "90"
    position x=3440 y=-500

    layout {
        default-column-width { proportion 1.0; }
    }
}

layout {
    gaps 8
    center-focused-column "never"

    default-column-width { proportion 0.5; }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    border {
        width 2
        active-gradient from="#ff64ff80" to="#9696ffff" angle=45
        inactive-color "#6464ff4d"
    }

    focus-ring {
        off
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#00000040"
    }
}

window-rule {
    geometry-corner-radius 10
    clip-to-geometry true
}

window-rule {
    match is-focused=false
    opacity 0.85
}

environment {
    QT_QPA_PLATFORM "wayland;xcb"
    QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
    QT_AUTO_SCREEN_SCALE_FACTOR "1"
    MOZ_ENABLE_WAYLAND "1"
    OZONE_PLATFORM "wayland"
    XCURSOR_SIZE "24"

    // For Wayland input methods, these should be unset (use native Wayland protocol)
    // GTK_IM_MODULE and QT_IM_MODULE intentionally not set
    // XMODIFIERS intentionally not set
}

spawn-at-startup "sh" "-c" "/home/moinax/.config/waybar/launch-waybar.sh"
spawn-at-startup "swayidle" "-w"
spawn-at-startup "swaybg" "-m" "fill" "-i" "/home/moinax/Wallpapers/colorful.jpg"
spawn-at-startup "mako"
{{ if eq .chezmoi.osRelease.id "fedora" -}}
spawn-at-startup "/usr/libexec/polkit-kde-authentication-agent-1"
{{ else -}}
spawn-at-startup "/usr/lib/polkit-kde-authentication-agent-1"
{{ end -}}
spawn-at-startup "blueman-applet"
spawn-at-startup "sh" "-c" "wl-paste --type text --watch cliphist store"
spawn-at-startup "sh" "-c" "wl-paste --type image --watch cliphist store"

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

binds {
    // Mod-Shift-/, which is usually the same as Mod-?,
    // shows a list of important hotkeys.
    // Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+H { show-hotkey-overlay; }

    // Custom app binds.
    Mod+Return hotkey-overlay-title="Open a Terminal: kitty" { spawn "kitty"; }
    Mod+Space hotkey-overlay-title="Run an Application: rofi" { spawn-sh "rofi -show drun"; }
    Mod+B hotkey-overlay-title="Open Browser: chrome" { spawn "google-chrome-stable" "--password-store=basic"; }
    Mod+E hotkey-overlay-title="Open File Manager: dolphin" { spawn "dolphin"; }
    Mod+I hotkey-overlay-title="Emoji Selector: rofi" { spawn-sh "rofi -show emoji -modi emoji"; }
    Mod+A hotkey-overlay-title="Switch Audio Output" { spawn-sh "~/.local/bin/toggle-audio-switch.sh"; }
    Mod+K hotkey-overlay-title="Switch Keyboard Layout" { spawn-sh "~/.local/bin/niri-switch-layout.sh"; }
    Mod+Tab hotkey-overlay-title="Switch Window: rofi" { spawn-sh "rofi -show window -window-thumbnail"; }

    // Keep default launcher too.
    Mod+D hotkey-overlay-title="Run an Application: fuzzel" { spawn "fuzzel"; }
    Mod+L hotkey-overlay-title="Open Power Menu: rofi" { spawn-sh "rofi -show powermenu -modi 'powermenu:rofi-power-menu'"; }
    Super+Alt+L hotkey-overlay-title="Lock the Screen: hyprlock" { spawn "hyprlock"; }

    // Reload configs (matching Hyprland Mod+Shift+B/W/M/R)
    Mod+Shift+B hotkey-overlay-title="Reload Waybar" { spawn-sh "killall -9 waybar; ~/.config/waybar/launch-waybar.sh &"; }
    Mod+Shift+W hotkey-overlay-title="Reload Wallpaper" { spawn-sh "killall swaybg; swaybg -m fill -i ~/Wallpapers/colorful.jpg &"; }
    Mod+Shift+M hotkey-overlay-title="Reload Mako" { spawn-sh "killall mako; mako &"; }
    Mod+Shift+R hotkey-overlay-title="Reload Niri Config" { spawn-sh "niri msg action load-config-file && notify-send -u low 'Niri' 'Config reloaded'"; }

    // Example volume keys mappings for PipeWire & WirePlumber.
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // Media keys
    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }

    // Brightness keys
    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // Overview
    Mod+O repeat=false { toggle-overview; }

    Mod+Q repeat=false { close-window; }

    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }

    // Window focus within column (tabs/stack).
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }

    // Workspace navigation on Page keys.
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up   { focus-workspace-up; }

    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Alt+Down { move-column-to-workspace-down; }
    Mod+Alt+Up   { move-column-to-workspace-up; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    Mod+Alt+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Alt+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Alt+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Alt+Ctrl+Right { move-column-to-monitor-right; }

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // Switch workspaces - QWERTY
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    // Switch workspaces - AZERTY
    Mod+ampersand { focus-workspace 1; }
    Mod+eacute { focus-workspace 2; }
    Mod+quotedbl { focus-workspace 3; }
    Mod+apostrophe { focus-workspace 4; }
    Mod+parenleft { focus-workspace 5; }
    Mod+minus { focus-workspace 6; }
    Mod+egrave { focus-workspace 7; }
    Mod+underscore { focus-workspace 8; }
    Mod+ccedilla { focus-workspace 9; }

    // Move window to workspace - QWERTY
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // Move window to workspace - AZERTY
    Mod+Ctrl+ampersand { move-column-to-workspace 1; }
    Mod+Ctrl+eacute { move-column-to-workspace 2; }
    Mod+Ctrl+quotedbl { move-column-to-workspace 3; }
    Mod+Ctrl+apostrophe { move-column-to-workspace 4; }
    Mod+Ctrl+parenleft { move-column-to-workspace 5; }
    Mod+Ctrl+minus { move-column-to-workspace 6; }
    Mod+Ctrl+egrave { move-column-to-workspace 7; }
    Mod+Ctrl+underscore { move-column-to-workspace 8; }
    Mod+Ctrl+ccedilla { move-column-to-workspace 9; }

    // Cross-boundary: focus monitor left/right (matches Mod+Alt = cross-boundary pattern).
    Mod+Alt+Left  { focus-monitor-left; }
    Mod+Alt+Right { focus-monitor-right; }
    // Column operations (T-group: Alt = column ops, Ctrl = display mode, Shift = undo).
    Mod+Alt+T { consume-window-into-column; }
    Mod+Alt+Shift+T { expel-window-from-column; }
    Mod+Ctrl+T { set-column-display "tabbed"; }
    Mod+Ctrl+Shift+T { set-column-display "normal"; }

    // Custom: keep your preferred actions.
    Mod+R { switch-preset-column-width; }
    Mod+Alt+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+Alt+F { fullscreen-window; }
    Mod+F { maximize-window-to-edges; }
    Mod+T { toggle-window-floating; }

    // Keep standard alternatives too.
    Mod+M { maximize-window-to-edges; }
    Mod+Alt+M { maximize-column; }
    Mod+C { center-column; }
    Mod+Ctrl+C { center-visible-columns; }

    // Resize with arrow keys (Minus/Equal removed to avoid AZERTY workspace conflicts)
    Mod+Shift+Right { set-column-width "+10%"; }
    Mod+Shift+Left { set-column-width "-10%"; }
    Mod+Shift+Up { set-window-height "-10%"; }
    Mod+Shift+Down { set-window-height "+10%"; }
    Mod+V hotkey-overlay-title="Clipboard: cliphist" { spawn-sh "cliphist list | rofi -dmenu | cliphist decode | wtype -"; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+E { quit; }
    Ctrl+Alt+Delete { quit; }
    Mod+Shift+P { power-off-monitors; }
}

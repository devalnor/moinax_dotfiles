// Niri config tuned to mirror Hyprland-like binds where possible.
// Keep this file conservative: invalid actions/keys can cause Niri to reject binds.
//
// Arrow-key modifier pattern:
//   Mod+Arrow              = Focus (column L/R, window U/D)
//   Mod+Page_Up/Down       = Focus workspace up/down
//   Mod+Alt+Arrow          = Cross-boundary (monitor L/R, workspace-move U/D)
//   Mod+Ctrl+Arrow         = Move window/column in direction
//   Mod+Shift+Arrow        = Resize (column width L/R, window height U/D)
//   Mod+Alt+Ctrl+Arrow     = Move column to monitor
//
// Column/tab keys (matching Hyprland muscle memory):
//   Mod+J / Mod+Shift+J    = Consume into / expel from column
//   Mod+G / Mod+Shift+G    = Tabbed display on / off
//
// Non-1:1 mappings with Hyprland:
// - Scratchpad, group, and split have no direct Niri equivalent.
// - "move to workspace silently" is approximated with regular move-to-workspace.

input {
    focus-follows-mouse max-scroll-amount="0%"

    keyboard {
        xkb {
            layout "be,fr,us"
            // Layout switching handled by Mod+K (niri-switch-layout.sh)
            // grp:alt_shift_toggle removed to avoid conflicts with Mod+Alt+Shift combos
        }
    }

    touchpad {
        tap
        dwt
        natural-scroll
        click-method "clickfinger"
    }
}

// DP-* stanzas are gated by hostname — connector names would otherwise
// match unrelated monitors on other hosts.

// Internal laptop panel (eDP-1) - 4K, scaled for readability
output "eDP-1" {
    scale 1.75
}

{{- if eq .chezmoi.hostname "moinax-desktop" }}

// Left Monitor (DP-2) - Vertical
output "DP-2" {
    mode "2560x1440@59.951"
    transform "90"
    position x=-1440 y=-500

    layout {
        default-column-width { proportion 1.0; }
    }
}

// Center Monitor (DP-3) - Ultrawide, primary
output "DP-3" {
    mode "3440x1440@174.962"
    transform "normal"
    position x=0 y=0
}

// Right Monitor (DP-1) - Vertical
output "DP-1" {
    mode "2560x1440@59.951"
    transform "90"
    position x=3440 y=-500

    layout {
        default-column-width { proportion 1.0; }
    }
}
{{- end }}

layout {
    gaps 8
    center-focused-column "never"

    default-column-width { proportion 0.5; }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    border {
        width 4
{{ if eq .dark_mode "light" -}}
        active-gradient from="#8839efcc" to="#1e66f5cc" angle=45
        inactive-color "#7287fd4d"
{{ else -}}
        active-gradient from="#ff64ff80" to="#9696ffff" angle=45
        inactive-color "#6464ff4d"
{{ end -}}
    }

    focus-ring {
        off
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#00000040"
    }
}

window-rule {
    geometry-corner-radius 10
    clip-to-geometry true
}

window-rule {
    match is-focused=true
    opacity 0.95
}

window-rule {
    match is-focused=false
    opacity 0.85
}


environment {
    QT_QPA_PLATFORM "wayland;xcb"
    QT_QPA_PLATFORMTHEME "kde"
    QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
    QT_AUTO_SCREEN_SCALE_FACTOR "1"
    MOZ_ENABLE_WAYLAND "1"
    OZONE_PLATFORM "wayland"
    XCURSOR_SIZE "24"

    // For Wayland input methods, these should be unset (use native Wayland protocol)
    // GTK_IM_MODULE and QT_IM_MODULE intentionally not set
    // XMODIFIERS intentionally not set
{{- if .has_nvidia }}

    // NVIDIA https://wiki.hyprland.org/Nvidia/
    LIBVA_DRIVER_NAME "nvidia"
    GBM_BACKEND "nvidia-drm"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    __GL_VRR_ALLOWED "1"
{{- end }}
}

// Daemons with their own user unit autostart via graphical-session.target.wants/.
// Inline daemons go through `uwsm app --` so they live in app-graphical.slice
// and stop with the session instead of being orphaned niri children.
spawn-at-startup "uwsm" "app" "--" "swayidle" "-w"
spawn-at-startup "uwsm" "app" "--" "{{ .chezmoi.homeDir }}/.local/bin/swayidle-resume-reset.sh"
spawn-at-startup "uwsm" "app" "--" "swaybg" "-m" "fill" "-i" "{{ .chezmoi.homeDir }}/Wallpapers/colorful.jpg"
spawn-at-startup "sh" "-c" "~/.local/bin/apply-dark-mode.sh"
{{ if .install_ai -}}
spawn-at-startup "systemctl" "--user" "start" "hyprvoice.service"
{{ end -}}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

recent-windows {
    binds {
        Mod+Shift+Tab { previous-window; }
    }
}

hotkey-overlay {
    skip-at-startup
}

binds {
    // ── 1. Application Shortcuts ──────────────────────────────────────
    Mod+Return hotkey-overlay-title="Open a Terminal: kitty" { spawn "kitty"; }
    Mod+Alt+Return hotkey-overlay-title="Pick Directory & Open Dev Terminal: kitty splits" { spawn-sh "~/.local/bin/kdev-launch.sh"; }
    Mod+Space hotkey-overlay-title="App Launcher: rofi" { spawn-sh "rofi -show drun"; }
    Mod+B hotkey-overlay-title="Open Browser: zen" { spawn "zen-browser"; }
    Mod+Alt+B hotkey-overlay-title="Open Browser: chrome" { spawn "google-chrome-stable" "--password-store=basic"; }
    Mod+E hotkey-overlay-title="Open File Manager: dolphin" { spawn "dolphin"; }
    Mod+I hotkey-overlay-title="Emoji Selector: rofimoji" { spawn-sh "~/.local/bin/emoji-picker.sh"; }
    Mod+A hotkey-overlay-title="Switch Audio Output" { spawn-sh "~/.local/bin/toggle-audio-switch.sh"; }
    Mod+K hotkey-overlay-title="Switch Keyboard Layout" { spawn-sh "~/.local/bin/niri-switch-layout.sh"; }
    Mod+Tab hotkey-overlay-title="Switch Window: rofi" { spawn-sh "rofi -show window -window-thumbnail"; }
    Mod+Escape hotkey-overlay-title="Kill Window: rofi" { spawn-sh "rofi -show 'Select App to Kill' -modi 'Select App to Kill:rofi-killwindow'"; }
    Mod+V hotkey-overlay-title="Clipboard: cliphist" { spawn-sh "cliphist list | rofi -dmenu -p 'Clipboard' | cliphist decode | wtype -"; }
{{ if ne .chezmoi.osRelease.id "fedora" -}}
    Mod+C hotkey-overlay-title="Calculator: rofi-calc" { spawn-sh "rofi -show calc"; }
{{ end -}}
    Mod+Ctrl+Alt+C hotkey-overlay-title="Calculator: kcalc" { spawn "kcalc"; }
    Mod+Shift+P hotkey-overlay-title="Color Picker: hyprpicker" { spawn "hyprpicker"; }
    Mod+R hotkey-overlay-title="Theme Selector: rofi" { spawn "rofi-theme-selector"; }
    Mod+M hotkey-overlay-title="Toggle Monitors" { spawn-sh "~/.local/bin/toggle-monitors.sh"; }
    {{ if .install_ai -}}
    Mod+D hotkey-overlay-title="Toggle Dictation: hyprvoice" { spawn-sh "~/.local/bin/toggle-dictation.sh"; }
    {{ end -}}

    // ── 2. Window Management ──────────────────────────────────────────
    Mod+Q repeat=false { close-window; }
    Mod+T { toggle-window-floating; }
    Mod+F { fullscreen-window; }
    Mod+Alt+F { maximize-window-to-edges; }
    Mod+Alt+M { maximize-column; }
    Mod+Alt+C { center-column; }
    Mod+Ctrl+C { center-visible-columns; }
    Mod+O repeat=false { toggle-window-rule-opacity; }
    Mod+Ctrl+O repeat=false { toggle-overview; }
    Mod+W { switch-preset-column-width; }
    Mod+Alt+W { switch-preset-window-height; }
    Mod+Ctrl+W { reset-window-height; }
    Mod+P { switch-focus-between-floating-and-tiling; }

    // ── 3. Focus Navigation ──────────────────────────────────────────
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }

    // ── 4. Move Window / Column ──────────────────────────────────────
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    // ── 5. Resize ────────────────────────────────────────────────────
    Mod+Shift+Left  { set-column-width "-10%"; }
    Mod+Shift+Right { set-column-width "+10%"; }
    Mod+Shift+Up    { set-window-height "-10%"; }
    Mod+Shift+Down  { set-window-height "+10%"; }

    // ── 6. Column / Group Operations ─────────────────────────────────
    Mod+J { consume-window-into-column; }
    Mod+Shift+J { expel-window-from-column; }
    Mod+G { toggle-column-tabbed-display; }
    Mod+Shift+G { set-column-display "normal"; }

    // ── 7. Workspace Navigation ──────────────────────────────────────
    // QWERTY
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    // AZERTY
    Mod+ampersand { focus-workspace 1; }
    Mod+eacute { focus-workspace 2; }
    Mod+quotedbl { focus-workspace 3; }
    Mod+apostrophe { focus-workspace 4; }
    Mod+parenleft { focus-workspace 5; }
    Mod+minus { focus-workspace 6; }
    Mod+egrave { focus-workspace 7; }
    // Directional
    Mod+Page_Up   { focus-workspace-up; }
    Mod+Page_Down { focus-workspace-down; }

    // ── 8. Move to Workspace ─────────────────────────────────────────
    // QWERTY
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    // AZERTY
    Mod+Shift+ampersand { move-column-to-workspace 1; }
    Mod+Shift+eacute { move-column-to-workspace 2; }
    Mod+Shift+quotedbl { move-column-to-workspace 3; }
    Mod+Shift+apostrophe { move-column-to-workspace 4; }
    Mod+Shift+parenleft { move-column-to-workspace 5; }
    Mod+Shift+minus { move-column-to-workspace 6; }
    Mod+Shift+egrave { move-column-to-workspace 7; }
    // Directional
    Mod+Shift+Page_Up   { move-column-to-workspace-up; }
    Mod+Shift+Page_Down { move-column-to-workspace-down; }
    Mod+Alt+Page_Up     { move-workspace-up; }
    Mod+Alt+Page_Down   { move-workspace-down; }

    // ── 9. Monitor Navigation ────────────────────────────────────────
    Mod+Alt+Left  { swap-window-left; }
    Mod+Alt+Right { swap-window-right; }
    Mod+Alt+Comma  { focus-monitor-left; }
    Mod+Alt+Period { focus-monitor-right; }
    Mod+Alt+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Alt+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Alt+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Alt+Ctrl+Down  { move-column-to-monitor-down; }

    // ── 11. Reload Configs ───────────────────────────────────────────
    Mod+Shift+B hotkey-overlay-title="Reload Waybar" { spawn-sh "systemctl --user restart waybar.service"; }
    Mod+Shift+W hotkey-overlay-title="Reload Wallpaper" { spawn-sh "killall swaybg; swaybg -m fill -i ~/Wallpapers/colorful.jpg &"; }
    Mod+Shift+M hotkey-overlay-title="Reload SwayNC" { spawn-sh "swaync-client -R && swaync-client -rs"; }
    Mod+Shift+R hotkey-overlay-title="Reload Niri Config" { spawn-sh "niri msg action load-config-file && notify-send -u low 'Niri' 'Config reloaded'"; }

    // ── 12. Screenshots ──────────────────────────────────────────────
    Print { screenshot-screen; }
    Mod+Print { screenshot-window; }
    Mod+Shift+Print { screenshot; }

    // ── 13. Media & Volume ───────────────────────────────────────────
    XF86AudioRaiseVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute        allow-when-locked=true { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "swayosd-client" "--input-volume" "mute-toggle"; }
    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "swayosd-client" "--brightness" "lower"; }

    // ── 14. Session & System ─────────────────────────────────────────
    Mod+N hotkey-overlay-title="Toggle Dark/Light Mode" { spawn-sh "~/.local/bin/toggle-dark-mode.sh"; }
    Mod+Alt+N hotkey-overlay-title="Toggle Caffeine Mode" { spawn-sh "~/.local/bin/toggle-caffeine.sh"; }
    Mod+Ctrl+N hotkey-overlay-title="Toggle Tailscale VPN" { spawn-sh "~/.local/bin/toggle-tailscale.sh"; }
    Mod+Shift+Q { quit; }
    Ctrl+Alt+Delete { quit; }
    Mod+L hotkey-overlay-title="Power Menu: wlogout" { spawn "wlogout-wrapper.sh"; }
    Mod+Alt+L hotkey-overlay-title="Lock Screen" { spawn-sh "loginctl lock-session"; }
    Mod+Ctrl+L hotkey-overlay-title="Suspend" { spawn-sh "systemctl suspend"; }
    Mod+Shift+L hotkey-overlay-title="Logout" { spawn-sh "~/.local/bin/compositor-logout.sh"; }
    Mod+Alt+P { power-off-monitors; }
    Mod+H hotkey-overlay-title="Keybinding Help: rofi" { spawn "rofi-keybindings"; }
    Mod+U hotkey-overlay-title="Toggle Notification Center" { spawn-sh "swaync-client -t"; }
    Mod+Alt+U hotkey-overlay-title="Toggle Do Not Disturb" { spawn-sh "swaync-client -d"; }

    // ── 15. Mouse & Scroll ───────────────────────────────────────────
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }
    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }
}

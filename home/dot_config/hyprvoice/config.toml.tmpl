# Hyprvoice configuration
# https://github.com/LeonardoTrapani/hyprvoice
#
# First-time setup: run `hyprvoice onboarding`
# Edit interactively: run `hyprvoice configure`
# Download a local model: `hyprvoice model download large-v3-turbo`
#
# Config hot-reloads automatically when saved.

# ── Recording ──────────────────────────────────────────────────
[recording]
sample_rate = 16000              # 16 kHz — standard for Whisper speech recognition
channels = 1                     # Mono
format = "s16"                   # 16-bit signed integers
buffer_size = 8192               # Internal buffer size in bytes
device = ""                      # Empty = default PipeWire microphone
channel_buffer_size = 30         # Audio frame buffer size
timeout = "5m"                   # Maximum recording duration per toggle

# ── Transcription ───────────────────────────────────────────────
[transcription]
provider = {{ .hyprvoice_provider | quote }}
model = {{ .hyprvoice_model | quote }}    # Multilingual model (EN+FR).
language = ""                    # Empty = auto-detect. Set "en" or "fr" to force a language.
streaming = false
{{- if eq .hyprvoice_provider "whisper-cpp" }}
threads = 0                      # 0 = auto (NumCPU - 1)
{{- end }}

# ── Providers ───────────────────────────────────────────────────
{{- if eq .hyprvoice_provider "groq" }}
[providers.groq]
api_key = ""                     # Set GROQ_API_KEY env var instead (recommended)
{{- else }}
# [providers.groq]
# api_key = ""                   # Or set GROQ_API_KEY env var
{{- end }}

# ── LLM Post-Processing (requires API key) ─────────────────────
[llm]
enabled = false                  # Set to true + configure a provider below for text cleanup

# ── Text Injection ──────────────────────────────────────────────
[injection]
backends = ["wtype", "clipboard"]  # wtype is Wayland-native; clipboard as fallback
wtype_timeout = "5s"
clipboard_timeout = "3s"

# ── Notifications ───────────────────────────────────────────────
[notifications]
enabled = true
type = "desktop"

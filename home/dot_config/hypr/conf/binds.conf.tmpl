# Hyprland Keybindings
# See https://wiki.hyprland.org/Configuring/Binds/ for more

# ── 1. Application Shortcuts ──────────────────────────────────────
bind = SUPER, RETURN, exec, kitty # Open terminal
bind = SUPER ALT, RETURN, exec, ~/.local/bin/kdev-launch.sh # Pick directory & open dev terminal (kitty splits)
bind = SUPER, SPACE, exec, rofi -show drun # App launcher
bind = SUPER, B, exec, zen-browser # Open browser (Zen)
bind = SUPER ALT, B, exec, google-chrome-stable --password-store=basic # Open browser (Chrome)
bind = SUPER, E, exec, dolphin # Open file manager
bind = SUPER, I, exec, ~/.local/bin/emoji-picker.sh # Emoji selector
bind = SUPER, A, exec, ~/.local/bin/toggle-audio-switch.sh # Switch audio output
bind = SUPER, K, exec, ~/.config/hypr/scripts/toggle-keyboard-layout.sh # Switch keyboard layout
bind = SUPER, TAB, exec, rofi -show window -window-thumbnail # Window switcher
bind = SUPER, Escape, exec, rofi -show "Select App to Kill" -modi "Select App to Kill:rofi-killwindow" # Kill window (rofi)
bind = SUPER, V, exec, cliphist list | rofi -dmenu -p "Clipboard" | cliphist decode | wtype - # Clipboard
bind = SUPER, C, exec, rofi -show calc # Calculator (rofi)
bind = SUPER ALT, C, exec, gnome-calculator # Open calculator
bind = SUPER SHIFT, P, exec, hyprpicker # Color picker
bind = SUPER, R, exec, rofi-theme-selector # Theme selector
bind = SUPER, M, exec, ~/.config/hypr/scripts/toggle-monitor-layout.sh # Toggle monitor layout
{{- if .install_ai }}
bind = SUPER, D, exec, ~/.local/bin/toggle-dictation.sh # Toggle dictation (speech-to-text)
{{- end }}

# ── 2. Window Management ──────────────────────────────────────────
bind = SUPER, Q, killactive # Close window
bind = SUPER, T, togglefloating # Toggle floating
bind = SUPER, F, fullscreen, 1 # Fullscreen
bind = SUPER ALT, F, fullscreen, 0 # Maximize
bind = SUPER, P, pin, # Pin window

# ── 3. Focus Navigation ──────────────────────────────────────────
bind = SUPER, left, movefocus, l # Move focus left
bind = SUPER, right, movefocus, r # Move focus right
bind = SUPER, up, movefocus, u # Move focus up
bind = SUPER, down, movefocus, d # Move focus down
bind = SUPER SHIFT, Tab, cyclenext, prev # Cycle prev window

# ── 4. Move Window / Column ──────────────────────────────────────
bind = SUPER CTRL, right, movewindoworgroup, r
bind = SUPER CTRL, left, movewindoworgroup, l
bind = SUPER CTRL, up, movewindoworgroup, u
bind = SUPER CTRL, down, movewindoworgroup, d
bind = SUPER ALT, right, swapwindow, r
bind = SUPER ALT, left, swapwindow, l
bind = SUPER ALT, up, swapwindow, u
bind = SUPER ALT, down, swapwindow, d

# ── 5. Resize ────────────────────────────────────────────────────
binde = SUPER SHIFT, right, resizeactive, 30 0
binde = SUPER SHIFT, left, resizeactive, -30 0
binde = SUPER SHIFT, up, resizeactive, 0 -30
binde = SUPER SHIFT, down, resizeactive, 0 30

# ── 6. Column / Group Operations ─────────────────────────────────
bind = SUPER, J, layoutmsg, togglesplit # Toggle split
bind = SUPER, G, togglegroup, # Toggle group
bind = ALT, TAB, changegroupactive, f # Cycle group forward
bind = ALT SHIFT, TAB, changegroupactive, b # Cycle group backward
bind = ALT CTRL, TAB, movegroupwindow, # Swap in group

# ── 7. Workspace Navigation ──────────────────────────────────────
# QWERTY
bind = SUPER, 1, workspace, 1
bind = SUPER, 2, workspace, 2
bind = SUPER, 3, workspace, 3
bind = SUPER, 4, workspace, 4
bind = SUPER, 5, workspace, 5
bind = SUPER, 6, workspace, 6
bind = SUPER, 7, workspace, 7
# AZERTY
bind = SUPER, ampersand, workspace, 1
bind = SUPER, eacute, workspace, 2
bind = SUPER, quotedbl, workspace, 3
bind = SUPER, apostrophe, workspace, 4
bind = SUPER, parenleft, workspace, 5
bind = SUPER, minus, workspace, 6
bind = SUPER, egrave, workspace, 7

# ── 8. Move to Workspace ─────────────────────────────────────────
# QWERTY
bind = SUPER SHIFT, 1, movetoworkspace, 1
bind = SUPER SHIFT, 2, movetoworkspace, 2
bind = SUPER SHIFT, 3, movetoworkspace, 3
bind = SUPER SHIFT, 4, movetoworkspace, 4
bind = SUPER SHIFT, 5, movetoworkspace, 5
bind = SUPER SHIFT, 6, movetoworkspace, 6
bind = SUPER SHIFT, 7, movetoworkspace, 7
# AZERTY
bind = SUPER SHIFT, ampersand, movetoworkspace, 1
bind = SUPER SHIFT, eacute, movetoworkspace, 2
bind = SUPER SHIFT, quotedbl, movetoworkspace, 3
bind = SUPER SHIFT, apostrophe, movetoworkspace, 4
bind = SUPER SHIFT, parenleft, movetoworkspace, 5
bind = SUPER SHIFT, minus, movetoworkspace, 6
bind = SUPER SHIFT, egrave, movetoworkspace, 7
# Silent move (AZERTY)
bind = SUPER CTRL, ampersand, movetoworkspacesilent, 1
bind = SUPER CTRL, eacute, movetoworkspacesilent, 2
bind = SUPER CTRL, quotedbl, movetoworkspacesilent, 3
bind = SUPER CTRL, apostrophe, movetoworkspacesilent, 4
bind = SUPER CTRL, parenleft, movetoworkspacesilent, 5
bind = SUPER CTRL, minus, movetoworkspacesilent, 6
bind = SUPER CTRL, egrave, movetoworkspacesilent, 7

# ── 10. Scratchpad ────────────────────────────────────────────────
bind = SUPER, S, togglespecialworkspace, # Open the scratchpad
bind = SUPER SHIFT, S, movetoworkspace, special # Move to scratchpad
bind = SUPER CTRL, S, movetoworkspacesilent, special # Move to scratchpad (silent)

# ── 11. Reload Configs ───────────────────────────────────────────
bind = SUPER SHIFT, B, exec, ~/.config/hypr/scripts/reload-waybar.sh # Reload Waybar
bind = SUPER SHIFT, W, exec, ~/.config/hypr/scripts/reload-hyprpaper.sh # Reload hyprpaper
bind = SUPER SHIFT, M, exec, ~/.config/hypr/scripts/reload-mako.sh # Reload notifications
bind = SUPER SHIFT, R, exec, ~/.config/hypr/scripts/reload-hyprland.sh # Reload hyprland

# ── 12. Screenshots ──────────────────────────────────────────────
bind = , PRINT, exec, hyprshot -m output # Screenshot a monitor
bind = SUPER, PRINT, exec, hyprshot -m window # Screenshot a window
bind = SUPER SHIFT, PRINT, exec, hyprshot -m region # Screenshot a region

# ── 13. Media & Volume ───────────────────────────────────────────
bind = , XF86AudioRaiseVolume, exec, ~/.local/bin/volume-control.sh up 5%
bind = , XF86AudioLowerVolume, exec, ~/.local/bin/volume-control.sh down 5%
bind = , XF86AudioMute, exec, ~/.local/bin/volume-control.sh mute

# ── 14. Session & System ─────────────────────────────────────────
bind = SUPER, N, exec, ~/.local/bin/toggle-dark-mode.sh # Toggle dark/light mode
bind = SUPER ALT, N, exec, ~/.local/bin/toggle-caffeine.sh # Toggle caffeine mode
bind = SUPER CTRL, N, exec, ~/.local/bin/toggle-tailscale.sh # Toggle Tailscale VPN
bind = SUPER SHIFT, Q, exit # Exit Hyprland
bind = SUPER, L, exec, wlogout-wrapper.sh # Power menu (wlogout)
bind = SUPER ALT, L, exec, loginctl lock-session # Lock screen
bind = SUPER CTRL, L, exec, systemctl suspend # Suspend
bind = SUPER SHIFT, L, exec, ~/.local/bin/compositor-logout.sh # Logout
bind = SUPER, H, exec, rofi-keybindings # Keybinding help (rofi)

# ── 15. Mouse & Scroll ───────────────────────────────────────────
bindm = SUPER, mouse:272, movewindow # Move window
bindm = SUPER, mouse:273, resizewindow # Resize window

# ── 16. Opacity ───────────────────────────────────────────────────
bind = SUPER, o, tagwindow, switch_opacity
windowrule = match:tag switch_opacity, opacity 1 override
bind = SUPER SHIFT, o, tagwindow, switch_opacity_half
windowrule = match:tag switch_opacity_half, opacity 0.5 override

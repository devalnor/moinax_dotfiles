-- Apps started at Hyprland launch
--
-- Daemons (waybar, swayosd, hyprpaper, swaync, hypridle, polkit agent,
-- cliphist, blueman-applet, dropbox, …) are systemd user services bound to
-- graphical-session.target — see home/dot_config/systemd/user/. uwsm
-- activates that target on session start and stops it on logout, so they
-- come up and go down with the compositor. Don't add daemon spawns here.
--
-- This hook is for one-shot actions that must run after the compositor is
-- live (Lua dispatch available) but don't have their own systemd lifecycle.
local home = assert(os.getenv("HOME"), "HOME not set")

hl.on("hyprland.start", function()
    -- Restore dark/light mode
    hl.exec_cmd(home .. "/.local/bin/apply-dark-mode.sh")

    -- Load Hyprland plugins
    hl.exec_cmd("hyprpm reload -n")
end)

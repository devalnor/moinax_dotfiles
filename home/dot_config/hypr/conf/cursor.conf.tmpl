env = XCURSOR_SIZE,24
{{ $primary := "" -}}
{{ if lookPath "xrandr" -}}
{{   $primary = output "bash" "-c" "xrandr --query 2>/dev/null | grep ' connected ' | while IFS= read -r line; do name=$(echo \"$line\" | awk '{print $1}'); rotation=$(echo \"$line\" | sed 's/(.*//' | grep -oE '\\b(left|right|inverted)\\b' || true); if [ -z \"$rotation\" ]; then mode=$(xrandr --query 2>/dev/null | grep -A1 \"^${name} connected\" | tail -1 | awk '{print $1}'); pixels=$(echo \"$mode\" | awk -Fx '{print $1 * $2}'); echo \"$pixels $name\"; fi; done | sort -rn | head -1 | awk '{print $2}'" | trim -}}
{{ end -}}
cursor {
{{- if $primary }}
    default_monitor = {{ $primary }}
{{- end }}
    use_cpu_buffer = true
    no_warps = true
}

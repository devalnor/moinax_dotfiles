-- See https://wiki.hypr.land/Configuring/Basics/Workspace-Rules/ for more
{{- if eq .chezmoi.hostname "moinax-desktop" }}
hl.workspace_rule({ workspace = "1", monitor = "DP-3", default = true })
hl.workspace_rule({ workspace = "2", monitor = "DP-3" })
hl.workspace_rule({ workspace = "3", monitor = "DP-3" })
hl.workspace_rule({ workspace = "4", monitor = "DP-3" })
hl.workspace_rule({ workspace = "5", monitor = "DP-3" })
-- Portrait monitors: when the workspace is flipped into the scrolling
-- layout (Mod+Alt+T), grow the tape vertically instead of horizontally.
-- Has no effect while the workspace stays on dwindle.
hl.workspace_rule({ workspace = "6", monitor = "DP-2", default = true, layout_opts = { direction = "down" } })
hl.workspace_rule({ workspace = "7", monitor = "DP-1", default = true, layout_opts = { direction = "down" } })
{{- end }}

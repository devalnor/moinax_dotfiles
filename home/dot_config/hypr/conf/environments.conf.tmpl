# Ensure ~/.local/bin is in PATH for all spawned processes
env = PATH,$HOME/.local/bin:$PATH

# XDG Desktop Portal
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_TYPE,wayland
env = XDG_SESSION_DESKTOP,Hyprland
env = XDG_MENU_PREFIX,plasma-

# QT
env = QT_QPA_PLATFORM,wayland;xcb
env = QT_QPA_PLATFORMTHEME,kde
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1
env = QT_AUTO_SCREEN_SCALE_FACTOR,1

# GTK
env = GDK_SCALE,1

# Mozilla
env = MOZ_ENABLE_WAYLAND,1

# Cursor: white-toned on mocha, black-toned on latte (the suffix names the
# cursor color, not the palette). hyprcursor falls back to xcursor.
{{ $cursor_theme := "catppuccin-mocha-dark-cursors" -}}
{{- if eq .dark_mode "light" }}{{ $cursor_theme = "catppuccin-latte-light-cursors" }}{{ end }}
env = XCURSOR_THEME,{{ $cursor_theme }}
env = XCURSOR_SIZE,24
env = HYPRCURSOR_THEME,{{ $cursor_theme }}
env = HYPRCURSOR_SIZE,24

# OZONE
env = OZONE_PLATFORM,wayland

# For KVM virtual machines
# env = WLR_NO_HARDWARE_CURSORS, 1
# env = WLR_RENDERER_ALLOW_SOFTWARE, 1
{{- if .has_nvidia }}

# NVIDIA https://wiki.hyprland.org/Nvidia/
env = LIBVA_DRIVER_NAME,nvidia
env = GBM_BACKEND,nvidia-drm
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = __GL_VRR_ALLOWED,1
{{ end }}

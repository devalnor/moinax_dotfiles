# Execute your favorite apps at launch
exec-once = swayosd-server -s ~/.config/swayosd/style.css
exec-once = ~/.config/waybar/launch-waybar.sh
exec-once = hyprpaper
exec-once = swaync
exec-once = /usr/lib/polkit-kde-authentication-agent-1 &
exec-once = hypridle
# Load bluetooth applet
exec-once = blueman-applet
# Load dropbox
exec-once = dropbox
# Load clipboard history
exec-once = wl-paste --type text --watch cliphist store # Stores only text data
exec-once = wl-paste --type image --watch cliphist store # Stores only image data
{{- if .install_ai }}
# Start dictation daemon
exec-once = hyprvoice serve
{{- end }}
# Restore dark/light mode
exec-once = ~/.local/bin/apply-dark-mode.sh
# Load hyprland plugins
exec-once = hyprpm reload -n

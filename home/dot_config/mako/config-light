# See `man 5 mako` for a full list of configuration options.

default-timeout=5000

width=600
height=600

font=FiraCode Nerd Font 10

background-color=#eff1f5dd
text-color=#4c4f69
border-color=#1e66f5
border-radius=8

[urgency=low]
default-timeout=3000
border-color=#6464ff

[urgency=normal]
default-timeout=15000
border-color=#1e66f5

[urgency=critical]
default-timeout=30000
border-color=#fe640b

# Add a section for volume notifications based on the hint
[app-name="volume-control"]
format=%s
border-color=#6464ff
progress-color=#6464ff4d
history=0
group-by=app-name
anchor=top-center
width=300
height=60

{
  // Workspaces
{{ if .install_niri }}
  "niri/workspaces": {
    "on-click": "activate",
  },
{{ end }}
{{ if .install_hyprland }}
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "hide-active": false,
    "all-outputs": false,
{{- if eq .chezmoi.hostname "moinax-desktop" }}
    "persistent-workspaces": {
      "DP-2": [6],
      "DP-1": [7],
      "DP-3": [1, 2, 3, 4, 5]
    },
    "persistent-only": true,
{{- else }}
    "persistent-only": false,
{{- end }}
    "move-to-monitor": false,
    "format": "{name} {icon}",
    "format-icons": {
      "1": "’ē©",
      "2": "’äĪ",
      "3": "’äĀ",
      "4": "’äĀ",
      "5": "’äĀ",
      "6": "’üĄ",
      "7": "’å╝",
      "active": "’åÆ",
      "default": "’äæ",
    },
  },
{{ end }}
  // Focused window
{{ if .install_niri }}
  "niri/window": {
  },
{{ end }}
{{ if .install_hyprland }}
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1",
    },
    "separate-outputs": true,
    "icon": true,
    "icon-size": 16,
  },
{{ end }}
  "custom/exit": {
    "format": "’Ćæ",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false,
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "’ĆŻ",
      "unlocked": "’é£",
    },
  },
  // System tray
  "tray": {
    // "icon-size": 21,
    "spacing": 10,
  },
  // Clock
  "clock": {
    // "timezone": "America/New_York",
    "format": "{:%H:%M - %d.%m}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // "format-alt": "{:%Y-%m-%d}",
  },
  // System
  "custom/system": {
    "format": "’éĆ ",
    "tooltip": false,
  },
  // CPU
  "cpu": {
    "format": "CPU {usage}% ",
    // "on-click": "alacritty -e htop"
    "on-click": "kitty -T btop btop",
  },
  // Memory
  "memory": {
    "format": "MEM {used}GB",
    // "on-click": "alacritty -e htop"
    "on-click": "kitty btop",
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "kitty btop",
  },
  "hyprland/language": {
    "format": "/ K {short}",
  },
  "group/stats": {
    "orientation": "horizontal",
    "modules": ["custom/system", "cpu", "memory"],
  },
  // Network
  "network": {
    "family": "ipv4",
    "format": "{ipaddr}",
    "format-wifi": "’ć½  {essid} {signalStrength}%",
    "format-ethernet": "’āü {bandwidthDownBytes}’āŚ {bandwidthUpBytes}’āś",
    "format-disconnected": "Not connected", //An empty format will hide the module.
    "tooltip-format": "’āü {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "’āü  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/waybar/scripts/open-network-manager.sh",
  },
  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "’ā¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{icon} {volume}% {format_source} ’Ŗö",
    "format-bluetooth-muted": "’Ć” {icon} ’Ŗö",
    "format-muted": "’Ć” {format_source}",
    "format-source": "’ä░ {volume}%",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’Ćź",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć”", "’Ć¦", "’Ć©"],
    },
    "on-click": "pavucontrol",
  },
  // Bluetooth
  "bluetooth": {
    "format": "’Ŗö {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": "",
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false,
  },
  // Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ĆŻ",
    },
    "on-click-right": "loginctl lock-session",
  },
}

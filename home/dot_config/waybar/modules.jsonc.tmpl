{
  // Workspaces
{{ if .install_niri }}
  "niri/workspaces": {
    "on-click": "activate",
  },
{{ end }}
{{ if .install_hyprland }}
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "hide-active": false,
    "all-outputs": false,
{{- if eq .chezmoi.hostname "moinax-desktop" }}
    "persistent-workspaces": {
      "DP-2": [6],
      "DP-1": [7],
      "DP-3": [1, 2, 3, 4, 5]
    },
    "persistent-only": true,
{{- else }}
    "persistent-only": false,
{{- end }}
    "move-to-monitor": false,
    "format": "{name} {icon}",
    "format-icons": {
      "1": "пЙ®",
      "2": "пД°",
      "3": "пД†",
      "4": "пД†",
      "5": "пД†",
      "6": "пБµ",
      "7": "пЖЉ",
      "active": "пЖТ",
      "default": "пДС",
    },
  },
{{ end }}
  // Focused window
{{ if .install_niri }}
  "niri/window": {
  },
{{ end }}
{{ if .install_hyprland }}
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1",
    },
    "separate-outputs": true,
    "icon": true,
    "icon-size": 16,
  },
{{ end }}
  "custom/exit": {
    "format": "пАС",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false,
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "пА£",
      "unlocked": "пВЬ",
    },
  },
  // System tray
  "tray": {
    // "icon-size": 21,
    "spacing": 10,
  },
  // Clock
  "clock": {
    // "timezone": "America/New_York",
    "format": "{:%d.%m - %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // "format-alt": "{:%Y-%m-%d}",
  },
  // System
  "custom/system": {
    "format": "пВА ",
    "tooltip": false,
  },
  // CPU
  "cpu": {
    "format": "пГ§ {usage}%  ",
    // "on-click": "alacritty -e htop"
    "on-click": "kitty -T btop btop",
  },
  // Memory
  "memory": {
    "format": "пИ≥ {used}G",
    // "on-click": "alacritty -e htop"
    "on-click": "kitty btop",
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "kitty btop",
  },
  "hyprland/language": {
    "format": "/ K {short}",
  },
  "group/stats": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory"],
  },
  // Network
  "network": {
    "family": "ipv4",
    "format": "{ipaddr}",
    "format-wifi": "пЗЂ {signalStrength}%",
    "format-ethernet": "пГБ {bandwidthDownBytes}пГЧ {bandwidthUpBytes}пГШ",
    "format-disconnected": "Not connected", //An empty format will hide the module.
    "tooltip-format": "пГБ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пЗЂ   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пГБ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/waybar/scripts/open-network-manager.sh",
  },
  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пГІ {capacity}%",
    "format-plugged": "пЗ¶ {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}",
    "format-bluetooth": "{icon} пКФ",
    "format-bluetooth-muted": "пА¶ пКФ",
    "format-muted": "пА¶",
    "format-source": "",
    "format-source-muted": " пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "пА•",
      "headset": "пА•",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": ["пА¶", "пАІ", "пА®"],
    },
    "on-click": "pavucontrol",
  },
  // Bluetooth
  "bluetooth": {
    "format": "пКФ",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": "",
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false,
  },
  // Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "пБЃ",
      "deactivated": "пА£",
    },
    "on-click-right": "loginctl lock-session",
  },
}

{{- /* Waybar config for Hyprland compositor — two bars: full and minimal */ -}}
[
  {
    "name": "full",
    "output": [],
    "spacing": 4,
    "include": [
      "~/.config/waybar/modules.jsonc"
    ],
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
{{- if .install_vibewatch }}
      "custom/vibewatch"
{{- end }}
    ],
    "modules-right": [
      "group/stats",
      "mpd",
      "pulseaudio",
      "custom/headset-battery",
      "battery",
      "custom/keyboard-layout",
      "custom/dark-mode",
      "custom/caffeine",
      "custom/tailscale",
      "tray",
      "clock",
      "custom/notification",
      "custom/exit"
    ]
  },
  {
    "name": "minimal",
    "output": [],
    "spacing": 4,
    "include": [
      "~/.config/waybar/modules.jsonc"
    ],
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
{{- if .install_vibewatch }}
      "custom/vibewatch"
{{- end }}
    ],
    "modules-right": [
      "battery",
      "tray",
      "clock",
      "custom/notification",
      "custom/exit"
    ]
  }
]

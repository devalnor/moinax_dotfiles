{
  "window.commandCenter": true,
  "workbench.activityBar.orientation": "vertical",
  "git.autofetch": true,
  "workbench.colorTheme": "Catppuccin Mocha",
  "editor.fontFamily": "JetBrains Mono",
  "git.confirmSync": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "git.mergeEditor": true,
  "git.allowForcePush": true,
  "git.confirmForcePush": false,
  "git.useForcePushIfIncludes": false,
  "git.useForcePushWithLease": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "diffEditor.renderSideBySide": true,
  "diffEditor.experimental.showMoves": true,
  "editor.minimap.enabled": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "git.openRepositoryInParentFolders": "never",
  "git.enableSmartCommit": true,
  "githubPullRequests.pullBranch": "never",
  "terminal.integrated.fontFamily": "Maple Mono NF",
  "terminal.integrated.fontLigatures.enabled": true,
  "workbench.iconTheme": "catppuccin-mocha",
  "diffEditor.maxComputationTime": 0,
  "editor.fontLigatures": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterNames.enabled": "all",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "git.replaceTagsWhenPull": true,
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "workbench.preferredDarkIconTheme": "catppuccin-mocha",
  "workbench.preferredLightIconTheme": "catppuccin-latte",
}

[Unit]
Description=SwayOSD server
PartOf=graphical-session.target
After=graphical-session.target
# See waybar.service for why: prevent the unit from entering start-limit-hit
# while it spins on Wayland-socket failures between logout and login.
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/usr/bin/swayosd-server -s %h/.config/swayosd/style.css
Restart=on-failure

[Install]
WantedBy=graphical-session.target

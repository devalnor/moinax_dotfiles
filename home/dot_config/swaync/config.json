{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-width": 400,
  "notification-window-width": 600,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "hide-on-clear": true,
  "hide-on-action": true,
  "notification-grouping": true,
  "notification-visibility": {
    "caffeine-toggle": {
      "state": "transient",
      "summary": "^Caffeine$"
    },
    "audio-switch": {
      "state": "transient",
      "summary": "^Audio Output Changed$"
    },
    "keyboard-layout": {
      "state": "transient",
      "summary": "^Keyboard Layout$"
    },
    "hyprland-status": {
      "state": "transient",
      "summary": "^Hyprland$"
    },
    "hyprland-layout": {
      "state": "transient",
      "app-name": "^Hyprland layout$"
    },
    "waybar-reload": {
      "state": "transient",
      "summary": "^Waybar$"
    },
    "hyprpaper-reload": {
      "state": "transient",
      "summary": "^Hyprpaper$"
    },
    "niri-status": {
      "state": "transient",
      "summary": "^Niri$"
    },
    "rofi-info": {
      "state": "transient",
      "summary": "^Rofi$"
    },
    "idle-warning": {
      "state": "transient",
      "summary": "Your computer will be locked"
    },
    "hyprvoice": {
      "state": "transient",
      "app-name": "Hyprvoice"
    },
    "claude-code": {
      "state": "transient",
      "summary": "Claude Code"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 48,
      "image-radius": 8,
      "blur": false
    }
  }
}

{{- if .install_development -}}
#!/bin/bash
# Configure Claude Code to use ccstatusline for the status bar.
# Merges the statusLine entry into ~/.claude/settings.json via jq
# without disturbing machine-specific keys (plugins, marketplaces, etc.).
set -e

CLAUDE_SETTINGS="$HOME/.claude/settings.json"

# Bail out if jq is not available
if ! command -v jq &>/dev/null; then
    echo "ccstatusline: jq not found, skipping Claude Code status line configuration"
    exit 0
fi

# Ensure the directory and file exist
mkdir -p "$HOME/.claude"
if [ ! -f "$CLAUDE_SETTINGS" ]; then
    echo '{}' > "$CLAUDE_SETTINGS"
fi

# Define the statusLine entry
STATUS_LINE='{"statusLine":{"type":"command","command":"npx -y ccstatusline@latest","padding":0}}'

# Merge into existing settings (jq * operator does a recursive merge)
tmp=$(mktemp)
if jq --argjson sl "$STATUS_LINE" '. * $sl' "$CLAUDE_SETTINGS" > "$tmp"; then
    mv "$tmp" "$CLAUDE_SETTINGS"
    echo "ccstatusline: Claude Code status line configured"
else
    rm -f "$tmp"
    echo "ccstatusline: failed to update Claude Code settings"
    exit 1
fi
{{- else -}}
#!/bin/bash
# Development group not selected — nothing to do
{{- end }}

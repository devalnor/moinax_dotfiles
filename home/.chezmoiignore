# Chezmoi ignore file
# Files listed here will not be managed by chezmoi based on conditions
# NOTE: patterns match against TARGET paths (e.g. .config/), not source paths (e.g. dot_config/)

# README and documentation
README.md
LICENSE

# Ignore Hyprland configs if not selected
{{- if not .install_hyprland }}
.config/hypr/hyprland.conf
.config/hypr/hypridle.conf
.config/hypr/hyprpaper.conf
.config/hypr/conf
.config/hypr/conf/**
.config/hypr/scripts
.config/hypr/scripts/**
{{- end }}
{{- if and (not .install_hyprland) (not .install_niri) }}
.config/hypr/hyprlock.conf
{{- end }}

# Ignore Niri configs if not selected
{{- if not .install_niri }}
.config/niri
.config/niri/**
.config/swayidle
.config/swayidle/**
.local/bin/swayidle-resume-reset.sh
{{- end }}
{{- if and (not .install_hyprland) (not .install_niri) }}
.config/xdg-desktop-portal
.config/xdg-desktop-portal/**
{{- end }}

# Ignore shared Wayland desktop components if neither compositor is selected
{{- if and (not .install_hyprland) (not .install_niri) }}
.config/waybar
.config/waybar/**
.config/rofi
.config/rofi/**
.config/swaync
.config/swaync/**
.config/wlogout
.config/wlogout/**
.local/share/rofi
.local/share/rofi/**
{{- end }}

# Ignore AI configs if not selected
{{- if not .install_ai }}
.config/hyprvoice
.config/hyprvoice/**
.local/bin/toggle-dictation.sh
{{- end }}

# Ignore Development configs if not selected
{{- if not .install_development }}
.config/nvim
.config/nvim/**
.config/Cursor
.config/Cursor/**
.config/delta
.config/delta/**
.config/gh-dash
.config/gh-dash/**
.config/worktrunk
.config/worktrunk/**
.config/ccstatusline
.config/ccstatusline/**
.claude
.claude/**
{{- end }}

# Neovim lazy-lock.json — managed via 'manage.sh lazy-lock' instead of chezmoi apply
.config/nvim/lazy-lock.json

# Active theme files managed by apply-dark-mode.sh (variants are still tracked)
.config/kitty/current-theme.conf
.config/swaync/style.css
.local/share/rofi/themes/moinax.rasi
.config/wlogout/style.css
.config/waybar/style.css

# Ignore desktop-only base dotfiles in terminal mode
{{- if eq .install_purpose "terminal" }}
.config/kitty
.config/kitty/**
Wallpapers
Wallpapers/**
{{- end }}

# Ignore Productivity configs if not selected
{{- if not .install_productivity }}
.icons
.icons/**
.themes
.themes/**
.local/share/applications/google-chrome.desktop
{{- end }}

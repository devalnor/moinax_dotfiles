{{- /* Chezmoi configuration template */ -}}
{{- /* This file prompts for values on first run and stores them */ -}}

{{- $distro := "" -}}
{{- if hasKey . "distro" -}}
{{-   $distro = .distro -}}
{{- else -}}
{{-   $distro = .chezmoi.osRelease.id -}}
{{- end -}}

{{- $install_hyprland := false -}}
{{- if hasKey . "install_hyprland" -}}
{{-   $install_hyprland = .install_hyprland -}}
{{- else -}}
{{-   $install_hyprland = promptBool "Install Hyprland (Wayland compositor)" -}}
{{- end -}}

{{- $install_niri := false -}}
{{- if hasKey . "install_niri" -}}
{{-   $install_niri = .install_niri -}}
{{- else -}}
{{-   $install_niri = promptBool "Install Niri (Wayland compositor)" -}}
{{- end -}}

{{- $install_development := false -}}
{{- if hasKey . "install_development" -}}
{{-   $install_development = .install_development -}}
{{- else -}}
{{-   $install_development = promptBool "Install Development tools" -}}
{{- end -}}

{{- $install_gaming := false -}}
{{- if hasKey . "install_gaming" -}}
{{-   $install_gaming = .install_gaming -}}
{{- else -}}
{{-   $install_gaming = promptBool "Install Gaming packages" -}}
{{- end -}}

{{- $install_multimedia := false -}}
{{- if hasKey . "install_multimedia" -}}
{{-   $install_multimedia = .install_multimedia -}}
{{- else -}}
{{-   $install_multimedia = promptBool "Install Multimedia packages" -}}
{{- end -}}

{{- $install_productivity := false -}}
{{- if hasKey . "install_productivity" -}}
{{-   $install_productivity = .install_productivity -}}
{{- else -}}
{{-   $install_productivity = promptBool "Install Productivity tools" -}}
{{- end -}}

{{- $install_ai := false -}}
{{- if hasKey . "install_ai" -}}
{{-   $install_ai = .install_ai -}}
{{- else -}}
{{-   $install_ai = promptBool "Install AI tools (voice dictation, assistants)" -}}
{{- end -}}

{{- $hyprvoice_provider := "whisper-cpp" -}}
{{- if hasKey . "hyprvoice_provider" -}}
{{-   $hyprvoice_provider = .hyprvoice_provider -}}
{{- else if $install_ai -}}
{{-   $hyprvoice_provider = promptString "Hyprvoice provider (whisper-cpp/groq)" "whisper-cpp" -}}
{{- end -}}

{{- $hyprvoice_model := "large-v3-turbo" -}}
{{- if hasKey . "hyprvoice_model" -}}
{{-   $hyprvoice_model = .hyprvoice_model -}}
{{- else if $install_ai -}}
{{-   if eq $hyprvoice_provider "groq" -}}
{{-     $hyprvoice_model = promptString "Groq whisper model (whisper-large-v3/whisper-large-v3-turbo)" "whisper-large-v3-turbo" -}}
{{-   else -}}
{{-     $hyprvoice_model = promptString "Whisper model for dictation (tiny/small/medium/large-v3-turbo)" "large-v3-turbo" -}}
{{-   end -}}
{{- end -}}

{{- $has_nvidia := false -}}
{{- if hasKey . "has_nvidia" -}}
{{-   $has_nvidia = .has_nvidia -}}
{{- else -}}
{{-   $has_nvidia = eq (output "bash" "-c" "lspci 2>/dev/null | grep -qi nvidia && echo true || echo false" | trim) "true" -}}
{{- end -}}

{{- $install_purpose := "desktop" -}}
{{- if hasKey . "install_purpose" -}}
{{-   $install_purpose = .install_purpose -}}
{{- end -}}

{{- $dark_mode := "dark" -}}
{{- if hasKey . "dark_mode" -}}
{{-   $dark_mode = .dark_mode -}}
{{- end -}}

{{- $source_dir := "" -}}
{{- if hasKey . "sourceDir" -}}
{{-   $source_dir = .sourceDir -}}
{{- else -}}
{{-   $source_dir = .chezmoi.sourceDir -}}
{{- end -}}

sourceDir = {{ $source_dir | quote }}

[data]
    distro = {{ $distro | quote }}
    install_hyprland = {{ $install_hyprland }}
    install_niri = {{ $install_niri }}
    install_development = {{ $install_development }}
    install_gaming = {{ $install_gaming }}
    install_multimedia = {{ $install_multimedia }}
    install_productivity = {{ $install_productivity }}
    install_ai = {{ $install_ai }}
    hyprvoice_provider = {{ $hyprvoice_provider | quote }}
    hyprvoice_model = {{ $hyprvoice_model | quote }}
    has_nvidia = {{ $has_nvidia }}
    install_purpose = {{ $install_purpose | quote }}
    dark_mode = {{ $dark_mode | quote }}

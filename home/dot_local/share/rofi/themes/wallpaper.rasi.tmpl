/* Wallpaper picker — self-contained image-grid theme.
 *
 * Deliberately does NOT @import moinax.rasi: that pulls in the launcher's
 * vertical-list template (rounded-template.rasi) and rofi's cascade then
 * keeps the 1-column / 480px-wide layout instead of this grid. So every
 * layout property is set explicitly here.
 *
 * Colors are templated from the chezmoi `dark_mode` flag; apply-dark-mode.sh
 * re-applies this file on every Mod+N toggle so it tracks the theme. */

* {
{{- if eq .dark_mode "light" }}
    bg0:    #eff1f5f2;
    fg0:    #4c4f69;
    fg2:    #5c5f77;
{{- else }}
    bg0:    #000000ee;
    fg0:    #cdd6f4;
    fg2:    #969696;
{{- end }}
    bg-input:   #6464ff4d;
    accent:     #ff64ff80;

    background-color:   transparent;
    text-color:         @fg0;
    margin:             0;
    padding:            0;
    spacing:            0;
}

window {
    location:           center;
    anchor:             center;
    width:              1200px;
    border-radius:      24px;
    background-color:   @bg0;
    padding:            24px;
}

mainbox {
    spacing:    18px;
    children:   [ inputbar, listview ];
}

inputbar {
    background-color:   @bg-input;
    border:             2px;
    border-color:       @accent;
    border-radius:      16px;
    padding:            10px 18px;
    spacing:            10px;
    children:           [ prompt, entry ];
}

prompt {
    text-color: @fg2;
}

entry {
    placeholder:        "Search wallpaper…";
    placeholder-color:  @fg2;
}

listview {
    background-color:   transparent;
    columns:            3;
    lines:              2;
    spacing:            18px;
    cycle:              true;
    scrollbar:          false;
    fixed-columns:      true;
}

element {
    orientation:        vertical;
    padding:            8px;
    border-radius:      16px;
    background-color:   transparent;
}

element selected {
    background-color:   @accent;
}

element-icon {
    size:               340px;
    border-radius:      12px;
    horizontal-align:   0.5;
}

element-text {
    horizontal-align:   0.5;
    vertical-align:     0.5;
    padding:            8px 4px 0px;
    text-color:         inherit;
}

element selected element-text {
    text-color:         @bg0;
}

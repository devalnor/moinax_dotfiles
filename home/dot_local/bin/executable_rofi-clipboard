#!/usr/bin/env bash
# rofi-clipboard — rofi script mode wrapper for cliphist
# Used as a combi source in the unified launcher.
# Usage: rofi -show clipboard -modi "clipboard:rofi-clipboard"
set -e

if [ -z "$1" ]; then
    cliphist list
else
    # Decode selected entry and type it
    echo "$1" | cliphist decode | wtype -
fi

#!/usr/bin/env bash
# rofi-filesearch — file search using fd, as a rofi script mode
# Used as a combi source in the unified launcher.
# Usage: rofi -show files -modi "files:rofi-filesearch"
#
# - Type a query to search files in $HOME
# - Enter opens the file with xdg-open
# - Shift+Enter copies the path to clipboard

# Detect fd binary (Arch/Fedora: fd, Debian: fdfind)
if command -v fd &>/dev/null; then
    FD_CMD="fd"
elif command -v fdfind &>/dev/null; then
    FD_CMD="fdfind"
else
    echo "fd not found"
    exit 1
fi

if [ -z "$1" ]; then
    # Initial call: show recent files as default listing
    $FD_CMD --type f --max-depth 3 --changed-within 7d \
        --base-directory "$HOME" \
        --strip-cwd-prefix 2>/dev/null | head -50
else
    # Check if the input is an existing file path (user selected a result)
    candidate="$HOME/$1"
    if [ -e "$candidate" ]; then
        if [ "$ROFI_RETV" = "10" ]; then
            # kb-custom-1 (Shift+Return): copy path to clipboard
            echo -n "$candidate" | wl-copy
            notify-send -u low "Rofi" "Path copied: $candidate"
        else
            # Default action: open with xdg-open
            xdg-open "$candidate" &>/dev/null &
        fi
    else
        # Input is a search query: run fd and return results
        $FD_CMD --type f --max-depth 5 \
            --base-directory "$HOME" \
            --strip-cwd-prefix \
            "$1" 2>/dev/null | head -50
    fi
fi

#!/usr/bin/env bash
# rofi-killwindow — list open windows via rofi, kill the selected one
# Used as rofi script mode: rofi -show "Select App to Kill" -modi "Select App to Kill:rofi-killwindow"
set -euo pipefail

. "$HOME/.local/lib/compositor.sh"

if [ -z "${1:-}" ]; then
    # Listing mode: output windows for rofi to display with icons
    if is_hyprland; then
        hyprctl clients -j | jq -r '
            .[] | select(.pid > 0) |
            "\(.class) — \(.title)\u0000icon\u001f\(.class | ascii_downcase)\u001finfo\u001f\(.pid)"'
    elif is_niri; then
        niri msg --json windows | jq -r '
            .[] | select(.pid > 0) |
            "\(.app_id) — \(.title)\u0000icon\u001f\(.app_id)\u001finfo\u001f\(.pid)"'
    fi
else
    # Selection mode: kill the chosen window's process
    pid="${ROFI_INFO:-}"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid"
        notify-send -u low "Kill Window" "Process $pid killed"
    fi
fi

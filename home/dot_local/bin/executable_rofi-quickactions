#!/usr/bin/env bash
# rofi-quickactions — system quick actions as a rofi script mode
# Used as a combi source in the unified launcher.
# Usage: rofi -show actions -modi "actions:rofi-quickactions"
set -e

if [ -z "$1" ]; then
    echo "󰒲  Toggle Dark/Light Mode"
    echo "󰅶  Toggle Caffeine"
    echo "󰛁  Toggle Tailscale VPN"
    echo "󰕾  Switch Audio Output"
    echo "󰌾  Lock Screen"
    echo "󰑐  Reload Waybar"
    echo "󰑐  Reload Compositor"
    echo "󰉋  Open File Manager"
    echo "󰆍  Open Terminal"
    echo "󰌌  Keybinding Help"
else
    case "$1" in
        *"Toggle Dark/Light Mode"*)
            ~/.local/bin/toggle-dark-mode.sh ;;
        *"Toggle Caffeine"*)
            ~/.local/bin/toggle-caffeine.sh ;;
        *"Toggle Tailscale"*)
            ~/.local/bin/toggle-tailscale.sh ;;
        *"Switch Audio Output"*)
            ~/.local/bin/toggle-audio-switch.sh ;;
        *"Lock Screen"*)
            loginctl lock-session ;;
        *"Reload Waybar"*)
            if pgrep -x niri &>/dev/null; then
                killall -9 waybar 2>/dev/null; ~/.config/waybar/launch-waybar.sh &
            else
                ~/.config/hypr/scripts/reload-waybar.sh
            fi ;;
        *"Reload Compositor"*)
            if pgrep -x niri &>/dev/null; then
                niri msg action load-config-file && notify-send -u low 'Niri' 'Config reloaded'
            else
                ~/.config/hypr/scripts/reload-hyprland.sh
            fi ;;
        *"Open File Manager"*)
            dolphin & ;;
        *"Open Terminal"*)
            kitty & ;;
        *"Keybinding Help"*)
            rofi-keybindings ;;
    esac
fi

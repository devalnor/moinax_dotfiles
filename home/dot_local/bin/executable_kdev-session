#!/bin/bash
# Emit kitty session config for the kdev/wts dev layout.
# Usage: kdev-session [extra-claude-args...]
#
# Args are re-quoted with printf %q: kitty re-tokenizes every `launch` line
# with shell-style splitting, so an unquoted `-n "my name"` would split into
# separate words and the trailing words would leak into claude's positional
# [prompt] -- launching claude with that text as an initial prompt.
claude_args=""
for arg in "$@"; do
  claude_args+=" $(printf '%q' "$arg")"
done

cat <<EOF
new_tab Claude
layout splits
launch --title kdev-claude claude$claude_args
launch --title kdev-lazygit --location=vsplit lazygit
focus_matching_window title:kdev-claude
launch --title kdev-term --location=hsplit
focus_matching_window title:kdev-claude

new_tab Neovim
launch nvim
EOF

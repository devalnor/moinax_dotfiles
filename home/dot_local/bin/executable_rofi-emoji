#!/usr/bin/env bash
# rofi-emoji — emoji picker as a rofi script mode
# Used as a combi source in the unified launcher.
# Usage: rofi -show emoji -modi "emoji:rofi-emoji"
set -e

if [ -z "$1" ]; then
    # List all emojis from rofimoji's installed data files
    # Glob avoids hardcoding the Python version in the path
    cat /usr/lib/python*/site-packages/picker/data/emojis_*.csv 2>/dev/null \
        | sed 's/<small>//g; s/<\/small>//g'
else
    # Extract emoji (everything before the first space) and copy+type it
    emoji="${1%% *}"
    echo -n "$emoji" | wl-copy
    wtype "$emoji"
fi

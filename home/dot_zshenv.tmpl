# This file is sourced for all zsh shells (interactive and non-interactive)
# Perfect for PATH configuration needed by VS Code and other tools

# Pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# fnm (Node.js version manager)
export FNM_PATH="$HOME/.local/share/fnm"
if [[ -d "$FNM_PATH" ]]; then
  export PATH="$FNM_PATH:$PATH"
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# Cargo (worktrunk, vibewatch, etc.)
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
case ":$PATH:" in
  *":$HOME/.cargo/bin:"*) ;;
  *) [[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH" ;;
esac

# Lazy docker, zoxide, ...
export PATH="$HOME/.local/bin:$PATH"

# Silence zoxide's "configuration issue" doctor. It fires a false positive in
# Claude Code's Bash tool: the shell snapshot replays zoxide's `cd` wrapper but
# not the `chpwd_functions+=(__zoxide_hook)` line from `zoxide init`, so the
# doctor sees a missing hook on every command. Zoxide still works fine.
export _ZO_DOCTOR=0
{{- if or .install_hyprland .install_niri }}
# Rofi scripts
export PATH="$HOME/.config/rofi/scripts:$PATH"
{{- end }}

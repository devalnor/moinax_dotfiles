# See `man 5 mako` for a full list of configuration options.

default-timeout=30000

width=600
height=600

font=FiraCode 10

background-color=#1e1e1edd
text-color=#cdd6f4
border-color=#89b4fa
border-radius=8

[urgency=low]
border-color=#94e2d5

[urgency=normal]
border-color=#89b4fa

[urgency=critical]
default-timeout=0
border-color=#fab387

# Add a section for volume notifications based on the hint
[app-name="volume-control"]
format=%s
border-color=#6464FF
progress-color=#6464FF4D
history=0
group-by=app-name
anchor=top-center
width=300
height=60
